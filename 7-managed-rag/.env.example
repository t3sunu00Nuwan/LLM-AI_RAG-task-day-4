# ── Azure AI Search ───────────────────────────────────────────────────────────
# Find these in the Azure Portal under your Search resource → Settings → Keys
AZURE_SEARCH_SERVICE_NAME=ai-search-test-course   # just the name, not the full URL
AZURE_SEARCH_INDEX_NAME=search-index-name
AZURE_SEARCH_API_KEY=api-key-...

# The name of the field in your index that holds the document text.
# Check your index schema in the Portal — often "content" or "chunk".
AZURE_SEARCH_CONTENT_FIELD=chunk

# How many chunks to retrieve per query
AZURE_SEARCH_TOP_K=3

# ── Azure OpenAI (Azure AI Foundry) ──────────────────────────────────────────
# Find these in Azure AI Foundry → your project → Settings → Connections
AZURE_OPENAI_ENDPOINT=set-this-from-foundry-model-details
AZURE_OPENAI_API_KEY=set-this-from-foundry-model-details
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini   # the deployment name you gave the model in Foundry
AZURE_OPENAI_API_VERSION=2024-12-01-preview
